<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Deliberate choice over SAF: archive analysis needs fast random access
         to multi-GB files. See README "Berechtigungen". -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- Extraction runs as a foreground service so multi-GB jobs survive
         the screen turning off -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Used for the manual update check and the explicitly started LAN receiver. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Android 17+ blocks incoming LAN sockets unless the user grants this
         runtime permission. It is requested only when LAN receive is started. -->
    <uses-permission android:name="android.permission.ACCESS_LOCAL_NETWORK" />

    <application
        android:name=".ThorRomButlerApp"
        android:localeConfig="@xml/locales_config"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:largeHeap="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.ThorRomButler">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.ThorRomButler">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Share target: "Share -> Thor ROM Butler" copies files into
                 the download folder and scans them -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>

        <!-- Permission bridge for starting LAN receive from the Quick Settings tile. -->
        <activity
            android:name=".receive.ReceivePermissionActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:theme="@style/Theme.ThorRomButler" />

        <service
            android:name=".extraction.ExtractionService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <service
            android:name=".receive.ReceiveService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Quick Settings tile: toggle LAN receive from the notification
             shade; exported + permission are required for SystemUI binding -->
        <service
            android:name=".receive.ReceiveTileService"
            android:exported="true"
            android:icon="@drawable/ic_notification_bolt"
            android:label="@string/receive_title"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <!-- On-demand WorkManager init (Configuration.Provider in the App
             class provides the HiltWorkerFactory) -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>

</manifest>
